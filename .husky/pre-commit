#!/bin/sh

# Get list of staged TypeScript files
STAGED_TS_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(ts|tsx)$')

if [ -z "$STAGED_TS_FILES" ]; then
  exit 0
fi

FAIL=0

# Check 1: Files over 600 lines
MAX_LINES=600
for FILE in $STAGED_TS_FILES; do
  if [ -f "$FILE" ]; then
    LINES=$(wc -l < "$FILE" | tr -d ' ')
    if [ "$LINES" -gt "$MAX_LINES" ]; then
      echo "Error: $FILE has $LINES lines (max: $MAX_LINES)"
      FAIL=1
    fi
  fi
done

if [ "$FAIL" -eq 1 ]; then
  echo ""
  echo "Pre-commit hook failed: Some TypeScript files exceed $MAX_LINES lines."
  echo "Please refactor large files into smaller modules."
  exit 1
fi

# Check 2: Deep relative imports (more than 2 levels up)
# Matches imports like ../../../, ../../../../, etc.
DEEP_IMPORT_PATTERN='from ["\x27]\.\.\/\.\.\/\.\.\/'

for FILE in $STAGED_TS_FILES; do
  if [ -f "$FILE" ]; then
    # Check for deep relative imports (3+ levels up)
    DEEP_IMPORTS=$(grep -nE "$DEEP_IMPORT_PATTERN" "$FILE" 2>/dev/null || true)
    if [ -n "$DEEP_IMPORTS" ]; then
      echo "Error: $FILE has deep relative imports (more than 2 levels up):"
      echo "$DEEP_IMPORTS" | while read -r line; do
        echo "  $line"
      done
      echo "  Use path aliases like @/ instead."
      FAIL=1
    fi
  fi
done

if [ "$FAIL" -eq 1 ]; then
  echo ""
  echo "Pre-commit hook failed: Deep relative imports detected."
  echo "Use path aliases (@/, @/types/) instead of ../../../ imports."
  echo ""
  echo "Available aliases:"
  echo "  @/*        -> src/*"
  echo "  @/types/*  -> types/*"
  exit 1
fi

exit 0
