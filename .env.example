# Better Auth + Prisma
# Use a production-grade Postgres database (Vercel Postgres, Neon, Supabase, etc.)
DATABASE_URL=
BETTER_AUTH_SECRET=
# Public app URL, for example: http://localhost:3000 or https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=
# Optional explicit Better Auth base URL. Falls back to NEXT_PUBLIC_APP_URL.
BETTER_AUTH_URL=

# Vercel Blob Storage (for storing rendered videos and caching sandboxes)
# Create a Blob store at: Vercel Dashboard -> Storage -> Create -> Blob
BLOB_READ_WRITE_TOKEN=
